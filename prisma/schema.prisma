generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  AUTHOR
  ADMIN
}

enum LicenseStage {
  G1
  G2
  G
}

enum UploadAssetType {
  LOGO
  FAVICON
  ROAD_SIGN
  BLOG_IMAGE
  CONTENT_IMAGE
  OTHER
}

enum ContentStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum ContentPostKind {
  BLOG
  NEWS
}

enum ManagedPageKind {
  TERMS
  PRIVACY
  CONTACT
  DISCLAIMER
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  MULTI_SELECT
}

enum QuestionReportReason {
  INCORRECT_ANSWER
  CONFUSING_EXPLANATION
  TYPO_GRAMMAR
  OUTDATED_RULE
  IMAGE_SIGN_ISSUE
  OTHER
}

enum RoadTestChecklistSection {
  BEFORE_TEST
  DURING_TEST
  COMMON_FAIL_REASONS
  SELF_ASSESSMENT
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  role           Role      @default(USER)
  currentStage   LicenseStage?
  targetTestDate DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  uploads  UploadAsset[]
  passwordResetTokens PasswordResetToken[]
  authoredPosts ContentPost[] @relation("ContentPostAuthor")
  reviewedPosts ContentPost[] @relation("ContentPostReviewer")
  authoredLessons Lesson[] @relation("LessonAuthor")
  reviewedLessons Lesson[] @relation("LessonReviewer")
  authoredQuestions Question[] @relation("QuestionAuthor")
  reviewedQuestions Question[] @relation("QuestionReviewer")
  contactSubmissions ContactSubmission[]
  quizAttempts QuizAttempt[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expires   DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UploadAsset {
  id           String          @id @default(cuid())
  type         UploadAssetType @default(OTHER)
  filename     String
  path         String
  mimeType     String
  sizeBytes    Int
  title        String?
  category     String?
  description  String?
  sourceCredit String?
  uploadedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  uploadedBy User? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  questionAssets QuestionAsset[]
  answerChoices AnswerChoice[]
  featuredPosts ContentPost[]

  @@index([type])
  @@index([uploadedById])
}

model Category {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  description String?
  stage       LicenseStage?
  sortOrder   Int           @default(0)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  lessons   Lesson[]
  questions Question[]
  checklistItems RoadTestChecklistItem[]
  quizAttemptAnswers QuizAttemptAnswer[]

  @@index([stage])
  @@index([isActive])
}

model Lesson {
  id            String        @id @default(cuid())
  slug          String        @unique
  title         String
  summary       String?
  body          String        @db.Text
  stage         LicenseStage
  categoryId    String?
  status        ContentStatus @default(DRAFT)
  sortOrder     Int           @default(0)
  authorId      String?
  reviewedById  String?
  publishedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author     User?     @relation("LessonAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  reviewedBy User?     @relation("LessonReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([stage, status])
  @@index([categoryId])
}

model Question {
  id              String        @id @default(cuid())
  type            QuestionType
  prompt          String        @db.Text
  explanation     String        @db.Text
  stage           LicenseStage
  categoryId      String?
  status          ContentStatus @default(DRAFT)
  selectCount     Int?
  sourceReference String?
  authorId        String?
  reviewedById    String?
  publishedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  category    Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author      User?          @relation("QuestionAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  reviewedBy  User?          @relation("QuestionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  choices     AnswerChoice[]
  assets      QuestionAsset[]
  reports     QuestionReport[]
  attemptAnswers QuizAttemptAnswer[]

  @@index([stage, status])
  @@index([categoryId])
}

model AnswerChoice {
  id          String  @id @default(cuid())
  questionId  String
  text        String?
  assetId     String?
  isCorrect   Boolean @default(false)
  sortOrder   Int     @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  asset    UploadAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([questionId])
  @@index([assetId])
}

model QuestionAsset {
  questionId String
  assetId    String
  sortOrder  Int @default(0)

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  asset    UploadAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([questionId, assetId])
  @@index([assetId])
}

model RoadTestChecklistItem {
  id          String                   @id @default(cuid())
  stage       LicenseStage
  section     RoadTestChecklistSection
  title       String
  description String?                  @db.Text
  categoryId  String?
  sortOrder   Int                      @default(0)
  isActive    Boolean                  @default(true)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([stage, section])
  @@index([isActive])
}

model QuizAttempt {
  id           String       @id @default(cuid())
  userId       String
  stage        LicenseStage
  correctCount Int
  totalCount   Int
  percent      Int
  createdAt    DateTime     @default(now())

  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers QuizAttemptAnswer[]

  @@index([userId, createdAt])
  @@index([stage, createdAt])
}

model QuizAttemptAnswer {
  id                String   @id @default(cuid())
  attemptId         String
  questionId        String
  categoryId        String?
  categoryName      String?
  isCorrect         Boolean
  selectedChoiceIds String[]
  correctChoiceIds  String[]
  createdAt         DateTime @default(now())

  attempt  QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([attemptId])
  @@index([questionId])
  @@index([categoryId])
  @@index([isCorrect])
}

model ContentPost {
  id              String          @id @default(cuid())
  kind            ContentPostKind
  status          ContentStatus   @default(DRAFT)
  title           String
  slug            String          @unique
  excerpt         String?
  body            String          @db.Text
  seoTitle        String?
  metaDescription String?
  tags            String[]
  featuredImageId String?
  authorId        String?
  reviewedById    String?
  publishedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  featuredImage UploadAsset? @relation(fields: [featuredImageId], references: [id], onDelete: SetNull)
  author        User?        @relation("ContentPostAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  reviewedBy    User?        @relation("ContentPostReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([kind, status])
  @@index([publishedAt])
}

model ManagedPage {
  id              String          @id @default(cuid())
  kind            ManagedPageKind @unique
  title           String
  slug            String          @unique
  body            String          @db.Text
  seoTitle        String?
  metaDescription String?
  updatedAt       DateTime        @updatedAt
  createdAt       DateTime        @default(now())
}

model FaqItem {
  id        String   @id @default(cuid())
  question  String
  answer    String   @db.Text
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model QuestionReport {
  id            String               @id @default(cuid())
  questionId    String
  reason        QuestionReportReason
  comment       String?              @db.Text
  reporterEmail String?
  reporterUserId String?
  ipHash        String?
  userAgent     String?
  resolvedAt    DateTime?
  createdAt     DateTime             @default(now())

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, resolvedAt])
  @@index([ipHash, createdAt])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  message   String   @db.Text
  resolvedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([resolvedAt])
}
